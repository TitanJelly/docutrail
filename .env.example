# Supabase project settings — copy this file to .env.local and fill in real values.
# All NEXT_PUBLIC_* vars are exposed to the browser; never put secrets there.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Server-only. Used by src/lib/supabase/admin.ts for IT-admin user provisioning.
# NEVER expose this to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct Postgres connection string for Drizzle migrations + server queries.
# Use the "Session" (port 5432) pooler string from Supabase → Project Settings → Database → Connection string → URI.
DATABASE_URL=postgresql://postgres.YOUR-PROJECT-REF:YOUR-DB-PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
